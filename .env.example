# ── PostgreSQL Connection ──────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_password_here

# ── Groq AI API ───────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Monitoring Thresholds ─────────────────────────────────────────────────────
# Capture queries slower than this (milliseconds)
SLOW_QUERY_THRESHOLD_MS=100.0
# Max queries to fetch per cycle
SLOW_QUERY_LIMIT=20
# How often the background daemon captures (minutes)
CAPTURE_INTERVAL_MINUTES=5

# ── Connection Pool ───────────────────────────────────────────────────────────
POOL_MIN_CONN=1
POOL_MAX_CONN=5

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# LOG_FILE defaults to <project_root>/logs/dba_agent.log

# ── SQLite Store ──────────────────────────────────────────────────────────────
# STORE_DB_PATH defaults to <project_root>/data/recommendations.db
# Override only if you want a custom location:
# STORE_DB_PATH=sqlite:////absolute/path/to/recommendations.db
